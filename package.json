{
  "name": "unplugin-yaml",
  "version": "4.2.0",
  "description": "Allow importing YAML files as JSON or Strings",
  "keywords": [
    "astro",
    "esbuild",
    "nuxt",
    "rolldown",
    "rolldown-plugin",
    "rollup",
    "rollup-plugin",
    "unplugin",
    "vite",
    "vite-plugin",
    "webpack",
    "yaml"
  ],
  "bugs": "https://github.com/luxass/unplugin-yaml/issues",
  "license": "MIT",
  "author": {
    "name": "Lucas Nørgård",
    "email": "lucasnrgaard@gmail.com",
    "url": "https://luxass.dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luxass/unplugin-yaml.git"
  },
  "workspaces": [
    "playground/*"
  ],
  "files": [
    "dist",
    "yaml.d.ts"
  ],
  "type": "module",
  "types": "dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./astro": "./dist/astro.mjs",
    "./constants": "./dist/constants.mjs",
    "./esbuild": "./dist/esbuild.mjs",
    "./nuxt": "./dist/nuxt.mjs",
    "./rolldown": "./dist/rolldown.mjs",
    "./rollup": "./dist/rollup.mjs",
    "./rspack": "./dist/rspack.mjs",
    "./types": {
      "types": "./yaml.d.ts"
    },
    "./vite": "./dist/vite.mjs",
    "./webpack": "./dist/webpack.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "vitest --run",
    "test:watch": "vitest",
    "play:vite": "pnpm --filter @unplugin-yaml/vite dev",
    "play:rspack": "pnpm --filter @unplugin-yaml/rspack dev",
    "typecheck": "tsc --noEmit && pnpm -r typecheck"
  },
  "dependencies": {
    "@rollup/pluginutils": "catalog:runtime",
    "unplugin": "catalog:runtime",
    "yaml": "catalog:runtime"
  },
  "devDependencies": {
    "@luxass/utils": "catalog:dev",
    "@nuxt/kit": "catalog:dev",
    "@nuxt/schema": "catalog:dev",
    "@rspack/core": "catalog:dev",
    "@types/node": "catalog:dev",
    "astro": "catalog:dev",
    "esbuild": "catalog:dev",
    "oxfmt": "catalog:dev",
    "oxlint": "catalog:dev",
    "oxlint-tsgolint": "catalog:dev",
    "publint": "catalog:dev",
    "rolldown": "catalog:dev",
    "rollup": "catalog:dev",
    "tsdown": "catalog:dev",
    "typescript": "catalog:dev",
    "vite": "catalog:dev",
    "vitest": "catalog:dev",
    "vitest-testdirs": "catalog:dev",
    "webpack": "catalog:dev"
  },
  "peerDependencies": {
    "@nuxt/kit": "^3.0.0 || ^4.0.0",
    "@nuxt/schema": "^3.0.0 || ^4.0.0",
    "@rspack/core": "^1.1.8 || ^2.0.0",
    "astro": "^3.0.0 || ^4.0.0 || ^5.0.0 || ^6.0.0",
    "esbuild": ">=0.19.12 <1",
    "rolldown": "^1.0.0",
    "rollup": ">=4 <5",
    "vite": "^6.0.0 || ^7.0.0 || ^8.0.0",
    "webpack": "^5.73.0"
  },
  "peerDependenciesMeta": {
    "@nuxt/kit": {
      "optional": true
    },
    "@nuxt/schema": {
      "optional": true
    },
    "astro": {
      "optional": true
    },
    "esbuild": {
      "optional": true
    },
    "rollup": {
      "optional": true
    },
    "vite": {
      "optional": true
    },
    "webpack": {
      "optional": true
    },
    "@rspack/core": {
      "optional": true
    },
    "rolldown": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.5.2"
}
